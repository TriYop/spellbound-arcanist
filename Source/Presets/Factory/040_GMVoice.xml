<?xml version="1.0" encoding="UTF-8"?>
<!-- Choir "Aaah!" hit + fading vocal tail: AM x2 triangle through LP 4500 Hz
     creates vowel formant sidebands; its own ADR envelope (0.5 s decay) means
     the formant is brightest on attack, then settles to a clean triangle tail. -->
<Parameters>
  <PARAM id="osc_waveform" value="1"/>
  <PARAM id="osc_tune" value="0"/>
  <PARAM id="osc_detune" value="12"/>
  <PARAM id="filter_cutoff" value="4500"/>
  <PARAM id="filter_resonance" value="0.25"/>
  <PARAM id="filter_mode" value="0"/>
  <PARAM id="env_attack" value="0.04"/>
  <PARAM id="env_decay" value="0.6"/>
  <PARAM id="env_sustain" value="0.08"/>
  <PARAM id="env_release" value="5.0"/>
  <PARAM id="env_filter_mod" value="40"/>
  <PARAM id="lfo_speed" value="0.5"/>
  <PARAM id="lfo_depth" value="25"/>
  <PARAM id="lfo_target" value="0"/>
  <PARAM id="output_gain" value="-3"/>
  <PARAM id="env_sustain_on" value="1"/>
  <PARAM id="fenv_attack" value="0.001"/>
  <PARAM id="fenv_decay" value="0.45"/>
  <PARAM id="fenv_sustain" value="0.0"/>
  <PARAM id="fenv_release" value="2.0"/>
  <PARAM id="fenv_sustain_on" value="0"/>
  <PARAM id="osc2_on" value="1"/>
  <PARAM id="osc2_waveform" value="1"/>
  <PARAM id="osc2_mult" value="2"/>
  <PARAM id="osc2_phase" value="0"/>
  <PARAM id="osc2_mix_mode" value="1"/>
  <PARAM id="osc2_mix_depth" value="40"/>
  <PARAM id="osc2_env_on" value="1"/>
  <PARAM id="osc2_env_attack" value="0.001"/>
  <PARAM id="osc2_env_decay" value="0.5"/>
  <PARAM id="osc2_env_sustain" value="0.0"/>
  <PARAM id="osc2_env_release" value="2.0"/>
  <PARAM id="osc2_env_sus_on" value="0"/>
  <PARAM id="osc2_flt_on" value="1"/>
  <PARAM id="osc2_flt_cutoff" value="4500"/>
  <PARAM id="osc2_flt_reso" value="0.1"/>
  <PARAM id="osc2_flt_mode" value="0"/>
  <PARAM id="osc2_fenv_atk" value="0.001"/>
  <PARAM id="osc2_fenv_dec" value="1.0"/>
  <PARAM id="osc2_fenv_sus" value="0.0"/>
  <PARAM id="osc2_fenv_rel" value="2.0"/>
  <PARAM id="osc2_fenv_sus_on" value="0"/>
  <PARAM id="osc2_fenv_depth" value="0"/>
</Parameters>
