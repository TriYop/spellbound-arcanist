<?xml version="1.0" encoding="UTF-8"?>
<!-- String ensemble stab + orchestral bloom: SAW+TRI sum always on for body,
     filter stab (env_filter_mod=35, fenv_decay=0.3) gives the initial brightness.
     Pitch LFO provides ensemble vibrato. -->
<Parameters>
  <PARAM id="osc_waveform" value="2"/>
  <PARAM id="osc_tune" value="0"/>
  <PARAM id="osc_detune" value="10"/>
  <PARAM id="filter_cutoff" value="4500"/>
  <PARAM id="filter_resonance" value="0.35"/>
  <PARAM id="filter_mode" value="0"/>
  <PARAM id="env_attack" value="0.005"/>
  <PARAM id="env_decay" value="0.45"/>
  <PARAM id="env_sustain" value="0.1"/>
  <PARAM id="env_release" value="5.5"/>
  <PARAM id="env_filter_mod" value="35"/>
  <PARAM id="lfo_speed" value="0.6"/>
  <PARAM id="lfo_depth" value="22"/>
  <PARAM id="lfo_target" value="2"/>
  <PARAM id="output_gain" value="-3"/>
  <PARAM id="env_sustain_on" value="1"/>
  <PARAM id="fenv_attack" value="0.005"/>
  <PARAM id="fenv_decay" value="0.3"/>
  <PARAM id="fenv_sustain" value="0.0"/>
  <PARAM id="fenv_release" value="2.0"/>
  <PARAM id="fenv_sustain_on" value="0"/>
  <PARAM id="osc2_on" value="1"/>
  <PARAM id="osc2_waveform" value="1"/>
  <PARAM id="osc2_mult" value="1"/>
  <PARAM id="osc2_phase" value="0"/>
  <PARAM id="osc2_mix_mode" value="0"/>
  <PARAM id="osc2_mix_depth" value="30"/>
  <PARAM id="osc2_env_on" value="0"/>
  <PARAM id="osc2_env_attack" value="0.005"/>
  <PARAM id="osc2_env_decay" value="0.4"/>
  <PARAM id="osc2_env_sustain" value="0.0"/>
  <PARAM id="osc2_env_release" value="2.0"/>
  <PARAM id="osc2_env_sus_on" value="0"/>
  <PARAM id="osc2_flt_on" value="0"/>
  <PARAM id="osc2_flt_cutoff" value="4000"/>
  <PARAM id="osc2_flt_reso" value="0.1"/>
  <PARAM id="osc2_flt_mode" value="0"/>
  <PARAM id="osc2_fenv_atk" value="0.001"/>
  <PARAM id="osc2_fenv_dec" value="1.0"/>
  <PARAM id="osc2_fenv_sus" value="0.0"/>
  <PARAM id="osc2_fenv_rel" value="2.0"/>
  <PARAM id="osc2_fenv_sus_on" value="0"/>
  <PARAM id="osc2_fenv_depth" value="0"/>
</Parameters>
